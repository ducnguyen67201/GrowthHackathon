# Copy to .env.local and fill in. Never commit .env.local.
OPENAI_API_KEY=
FIBER_API_KEY=

# Set by `npx convex dev`:
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Gmail app password (not your login password) for send + IMAP reply poll:
GMAIL_USER=
GMAIL_APP_PASSWORD=

APP_BASE_URL=http://localhost:3000
