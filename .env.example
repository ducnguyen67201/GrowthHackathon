# Copy to .env.local and fill in. Never commit .env.local.
OPENAI_API_KEY=
FIBER_API_KEY=

# Orange Slice — execution layer. Optional: when unset, sends fall back to Gmail.
# Used inside a Convex action, so ALSO set it in Convex: `npx convex env set ORANGESLICE_API_KEY <key>`.
# ORANGESLICE_BASE / ORANGESLICE_SEND_PATH only needed if the confirmed endpoint differs.
ORANGESLICE_API_KEY=
# ORANGESLICE_BASE=https://api.orangeslice.ai
# ORANGESLICE_SEND_PATH=/v1/outreach/send

# Set by `npx convex dev`:
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Gmail app password (not your login password) for send + IMAP reply poll:
GMAIL_USER=
GMAIL_APP_PASSWORD=

APP_BASE_URL=http://localhost:3000

# Demo mode: skip real email send. The funnel still resolves "sent" with no creds.
# Set in Convex (it runs in an action): `npx convex env set SEND_DRY_RUN 1`
SEND_DRY_RUN=

# AI image backdrop: generate a gpt-image-1 texture behind the (still exact-text) card.
# Read by Next (renderArtifact), needs OPENAI_API_KEY. Off unless set. Optional model override.
AI_BACKDROP=
# AI_BACKDROP_MODEL=gpt-image-1

# Real personalized video on Send (Remotion+TTS). Heavy (~10-60s). Off unless set; saved to /public/generated.
SEND_GEN_VIDEO=
